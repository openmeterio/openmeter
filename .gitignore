# devenv / nix shell state leaks into any cwd that runs `nix develop`,
# including the repo root and subdirectories like `openmeter/ent/` where
# code generation invokes `nix develop` to get a toolchain. Ignore these
# at any depth so generation never produces tracked artifacts.
.devenv/
.direnv/
.pre-commit-config.yaml

# Stray .nvmrc files dropped by devenv's `enterShell` into any nested
# directory that hosts a `nix develop` invocation. The root .nvmrc is
# committed (it's the GitHub Actions Node version source-of-truth), so
# we re-include it explicitly below.
.nvmrc
!/.nvmrc

/.env.local
/build/
/config.yaml
/tmp/

.tmp.*

.DS_Store

# Go workspace file
go.work
go.work.sum

__debug_bin*

openmeter.log

.gocache
.gomodcache

# Claude Code (local settings and session files)
.claude/settings.local.json
.claude/plans/
.claude/todos.json
.claude/worktrees
CLAUDE.local.md

# oapi-codegen patched templates (generated from patch files)
api/v3/templates/chi-middleware.tmpl

# CodeGraph
.codegraph/
