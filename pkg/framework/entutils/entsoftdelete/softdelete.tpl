{{/*
    Generates per-node soft-delete cascade walkers.

    For every Node `n` whose schema declares a `deleted_at` field, this
    template emits a `softDeleteCascade<n.Name>` function that walks each
    outgoing assoc edge whose target Node also has `deleted_at` (and which
    is not opted out via `softdelete.NoCascade()`), stamps `deleted_at` on
    currently-active descendants, and recurses into the child's walker via
    `softdelete.RunCascadeFor` so init() ordering is irrelevant.

    Walker signature (matches softdelete.CascadeFunc):

        func softDeleteCascade<Node>(
            ctx context.Context,
            client any,
            parentIDs []string,
        ) error

    The walker type-asserts `client` to `*Client` (the package-local one)
    so cascade writes participate in the caller's transaction.

    Each soft-delete-bearing node also emits an `init()` that registers its
    walker with the runtime registry.

    Edge selection — we cascade into edges where THIS node is the parent
    (i.e. dependents carry the FK to us):

      - inverse edges (edge.From) — skipped (this side references the
        parent; cascading "up" toward the parent is wrong)
      - assoc edges where THIS side owns the FK (M2O / O2O inverse) —
        skipped for the same reason: a junction-style table that declares
        `edge.To(parent, ...).Field("parent_id")` is referencing a parent,
        not a child
      - M2M edges — skipped (no `deleted_at` on the join table)
      - target without `deleted_at` — skipped
      - softdelete.NoCascade() annotation present — skipped

    The remaining edges are O2M and O2O-non-inverse, which is exactly the
    "I am the parent, dependents carry my ID" relationship.
*/}}
{{ define "entsoftdelete" }}

{{ $pkg := base $.Config.Package }}
{{ template "header" $ }}

{{/* Build the set of node names that carry a `deleted_at` field and are
     regular tables (not ent views). Views are silently excluded — they
     have no ID and no Update builder, so soft-delete cascade is
     meaningless for them. We also build a set of (Package() -> Type) for
     soft-delete target packages so we can explicitly emit aliased imports
     below; goimports does not know about ent's package aliases. */}}
{{ $softNodes := dict }}
{{ $softPkgs := dict }}
{{ range $n := $.Nodes }}
    {{ if not $n.IsView }}
        {{ range $f := $n.Fields }}
            {{ if eq $f.Name "deleted_at" }}
                {{ $_ := set $softNodes $n.Name true }}
                {{ $_ := set $softPkgs $n.Package $n }}
            {{ end }}
        {{ end }}
    {{ end }}
{{ end }}

import (
    "context"
    "fmt"

    "github.com/openmeterio/openmeter/pkg/clock"
    "github.com/openmeterio/openmeter/pkg/framework/entutils/softdelete"
{{ range $alias, $n := $softPkgs }}
    {{- if eq $alias $n.PackageDir }}
    "github.com/openmeterio/openmeter/openmeter/ent/db/{{ $n.PackageDir }}"
    {{- else }}
    {{ $alias }} "github.com/openmeterio/openmeter/openmeter/ent/db/{{ $n.PackageDir }}"
    {{- end }}
{{ end }}
)

{{ range $n := $.Nodes }}
    {{/* Skip ent views — they have no ID and cannot be soft-deleted. */}}
    {{ if and (hasKey $softNodes $n.Name) (not $n.IsView) $n.ID }}

// softDeleteCascade{{ $n.Name }} soft-deletes every dependent of the given
// {{ $n.Name }} parents that is itself a soft-delete-bearing entity.
//
// Generated by pkg/framework/entutils/entsoftdelete. Do not edit by hand.
func softDeleteCascade{{ $n.Name }}(ctx context.Context, client any, parentIDs []any) error {
    if len(parentIDs) == 0 {
        return nil
    }
    c, ok := client.(*Client)
    if !ok {
        return fmt.Errorf("softdelete: cascade for {{ $n.Name }} received client of type %T, want *Client", client)
    }
    now := clock.Now()
    _ = c
    _ = now

    // Type-assert parent IDs once. Walkers run only with IDs of the
    // parent's actual ID type (string ULID for top-level entities; int
    // for the handful of junction tables that get reached by recursion).
    parentIDsTyped := make([]{{ $n.ID.Type }}, 0, len(parentIDs))
    for _, id := range parentIDs {
        v, ok := id.({{ $n.ID.Type }})
        if !ok {
            return fmt.Errorf("softdelete: cascade for {{ $n.Name }} got id of type %T, want {{ $n.ID.Type }}", id)
        }
        parentIDsTyped = append(parentIDsTyped, v)
    }
    if len(parentIDsTyped) == 0 {
        return nil
    }
    _ = parentIDsTyped

    {{/*
        PASS 1 — outgoing assoc edges (edge.To) where the child holds the FK.
        These are O2M / O2O-non-inverse relationships ("I am the parent,
        dependents carry my ID").
    */}}
    {{ range $e := $n.Edges }}
        {{ if and (not $e.IsInverse) (not $e.OwnFK) (not $e.M2M) }}
            {{ if hasKey $softNodes $e.Type.Name }}
                {{ if not (hasKey $e.Annotations "SoftDeleteNoCascade") }}
                    {{ if and $e.Rel.Columns (gt (len $e.Rel.Columns) 0) }}
                        {{ $fkCol := index $e.Rel.Columns 0 }}
                        {{ $childPkg := $e.Type.Package }}
                        {{ $childName := $e.Type.Name }}
                        {{ $fkPredicate := print (pascal $fkCol) "In" }}

    // Cascade through {{ $n.Name }}.{{ $e.Name }} -> {{ $childName }}
    // FK column on {{ $childName }}: {{ $fkCol }}
    {
        childIDs, err := c.{{ $childName }}.Query().
            Where({{ $childPkg }}.{{ $fkPredicate }}(parentIDsTyped...)).
            IDs(ctx)
        if err != nil {
            return fmt.Errorf("softdelete: query {{ $childName }} children of {{ $n.Name }}: %w", err)
        }
        if len(childIDs) > 0 {
            if _, err := c.{{ $childName }}.Update().
                Where({{ $childPkg }}.IDIn(childIDs...)).
                SetDeletedAt(now).
                Save(ctx); err != nil {
                return fmt.Errorf("softdelete: stamp {{ $childName }} deleted_at: %w", err)
            }
            childIDsAny := make([]any, len(childIDs))
            for i, id := range childIDs {
                childIDsAny[i] = id
            }
            if err := softdelete.RunCascadeFor(ctx, "{{ $childName }}", c, childIDsAny); err != nil {
                return err
            }
        }
    }
                    {{ end }}
                {{ end }}
            {{ end }}
        {{ end }}
    {{ end }}

    {{/*
        PASS 2 — inbound assoc edges where some other node declares
        `edge.To(thisNode, ...).Field(parentFKCol)` and owns the FK on its
        side. These are M2O / O2O-inverse relationships where the schema
        author did NOT declare a reverse `edge.From` on this node (so PASS
        1 missed them).

        Concrete openmeter case this catches: AppStripeCustomer declares
        `edge.To("customer", Customer.Type).Field("customer_id")` but
        Customer does not declare a matching outgoing edge to
        AppStripeCustomer. Without this pass, deleting a Customer would
        leave AppStripeCustomer rows pointing at a tombstoned parent.

        We also skip any inbound that is already covered by an outgoing
        edge in PASS 1, to avoid double-stamping.
    */}}
    {{ $coveredByPass1 := dict }}
    {{ range $e := $n.Edges }}
        {{ if and (not $e.IsInverse) (not $e.OwnFK) (not $e.M2M) (hasKey $softNodes $e.Type.Name) }}
            {{ $_ := set $coveredByPass1 $e.Type.Name true }}
        {{ end }}
    {{ end }}
    {{ range $other := $.Nodes }}
        {{ if and (hasKey $softNodes $other.Name) (ne $other.Name $n.Name) (not (hasKey $coveredByPass1 $other.Name)) }}
            {{ range $e := $other.Edges }}
                {{/*
                    The inbound edge we want is one declared on $other that
                    points back to $n and owns the FK on $other's side.
                    `edge.To(n, ...).OwnFK()` matches that. We also accept
                    inverse edges that own the FK (edge.From with Field)
                    when the other side declares a reverse to here.
                */}}
                {{ if and $e.OwnFK (eq $e.Type.Name $n.Name) (not $e.M2M) }}
                    {{ if not (hasKey $e.Annotations "SoftDeleteNoCascade") }}
                        {{ if and $e.Rel.Columns (gt (len $e.Rel.Columns) 0) }}
                            {{ $fkCol := index $e.Rel.Columns 0 }}
                            {{ $childPkg := $other.Package }}
                            {{ $childName := $other.Name }}
                            {{ $fkPredicate := print (pascal $fkCol) "In" }}

    // Inbound cascade: {{ $childName }}.{{ $e.Name }} -> {{ $n.Name }}
    // ({{ $childName }} owns FK {{ $fkCol }}; {{ $n.Name }} has no reverse edge)
    {
        childIDs, err := c.{{ $childName }}.Query().
            Where({{ $childPkg }}.{{ $fkPredicate }}(parentIDsTyped...)).
            IDs(ctx)
        if err != nil {
            return fmt.Errorf("softdelete: query {{ $childName }} inbound to {{ $n.Name }}: %w", err)
        }
        if len(childIDs) > 0 {
            if _, err := c.{{ $childName }}.Update().
                Where({{ $childPkg }}.IDIn(childIDs...)).
                SetDeletedAt(now).
                Save(ctx); err != nil {
                return fmt.Errorf("softdelete: stamp {{ $childName }} deleted_at: %w", err)
            }
            childIDsAny := make([]any, len(childIDs))
            for i, id := range childIDs {
                childIDsAny[i] = id
            }
            if err := softdelete.RunCascadeFor(ctx, "{{ $childName }}", c, childIDsAny); err != nil {
                return err
            }
        }
    }
                        {{ end }}
                    {{ end }}
                {{ end }}
            {{ end }}
        {{ end }}
    {{ end }}

    return nil
}

func init() {
    softdelete.Register("{{ $n.Name }}", softDeleteCascade{{ $n.Name }})
}

    {{ end }}
{{ end }}

{{ end }}
