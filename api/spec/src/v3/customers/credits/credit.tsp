import "../../shared/index.tsp";
import "../../currencies/index.tsp";

namespace Customers;

/**
 * How the credit grant is funded.
 *
 * - `promotional`: Free credits, no charge or invoice.
 * - `invoiced`: Credits purchased via an invoice generated by the system.
 * - `externally_settled`: Credits paid outside the system (e.g. wire, ERP).
 *    The cost basis is recorded for revenue recognition but no invoice is created.
 */
@friendlyName("BillingCreditGrantType")
enum CreditGrantType {
  Promotional: "promotional",
  Invoiced: "invoiced",
  ExternallySettled: "externally_settled",
}

/**
 * When credits become available for burn-down after a purchase.
 *
 * - `immediate`: Credits are available as soon as the grant is created.
 *    Use for promotional grants or when payment risk is accepted.
 * - `on_payment_authorized`: Credits are available once the payment provider
 *    authorizes the charge (funds are held but not yet captured).
 * - `on_payment_settled`: Credits are available only after the payment is
 *    fully captured/settled. Safest option for prepaid self-serve.
 *
 * Only applicable when `type` is `invoiced`. Ignored otherwise.
 */
@friendlyName("BillingCreditAvailabilityPolicy")
enum CreditAvailabilityPolicy {
  Immediate: "immediate",
  // OnPaymentAuthorized: "on_payment_authorized",
  // OnPaymentSettled: "on_payment_settled",
}

/**
 * The lifecycle status of the credit grant.
 *
 * Grants transition through: `draft → active → consumed | expired | voided` states.
 */
@friendlyName("BillingCreditGrantStatus")
enum CreditGrantStatus {
  /** Grant created but not yet effective (`effective_at` is in the future). */
  Draft: "draft",

  /** Grant is active and credits are available for burn-down. */
  Active: "active",

  /** All credits have been consumed via usage. */
  Consumed: "consumed",

  /** Grant reached its `expires_at` date with remaining balance. */
  Expired: "expired",

  /** Grant was voided by an admin. Remaining balance is forfeited. */
  Voided: "voided",
}

/**
 * A credit grant represents an allocation of prepaid credits to a customer.
 *
 * Credits are drawn down against usage-based prices according to the
 * settlement mode configured on the rate card (`credit_then_invoice` or
 * `credit_only`).
 *
 * ### Charge types
 *
 * | Type                  | Invoice created? | Payment expected? | Use case                          |
 * |-----------------------|------------------|-------------------|-----------------------------------|
 * | `promotional`         | No               | No                | Free trials, promos, SLA credits  |
 * | `invoiced`            | Yes              | Yes               | Self-serve prepaid, enterprise    |
 * | `externally_settled`  | No               | Already paid      | Wire transfers, ERP-invoiced      |
 *
 * ### Priority & draw-down
 *
 * When multiple grants are active, credits are consumed in `priority` order
 * (lowest number first). Ties are broken by `effective_at` (earliest first).
 */
@friendlyName("BillingCreditGrant")
model CreditGrant {
  ...Shared.Resource;

  /**
   * The charge type of this credit grant.
   *
   * Determines whether an invoice is generated, whether payment is expected,
   * and which fields are required/applicable.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  type: CreditGrantType;

  /**
   * The credit instrument.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  credit: {
    /**
     * The currency of the credit grant.
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    currency: Shared.CurrencyCode; // | Currencies.CurrencyCodeCustom;

    /**
     * The amount of the credit grant.
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    amount: Shared.Numeric;
  };

  /**
   * The charge that will be used to purchase the credit.
   * Omit for promotional credit grants.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  purchase?: {
    /**
     * The currency of the charge.
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    currency: Shared.CurrencyCode;

    /**
     * The amount of the charge.
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    amount: Shared.Numeric;

    /**
     * The cost basis per credit unit.
     *
     * Determines both the charge amount and how revenue is recognized.
     * If `per_unit_cost_basis` is 0.50 and credit amount is $100.00,
     * the total charge is $50.00.
     *
     * Defaults to 1.0 (1:1 ratio between credit and charge currency).
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    per_unit_cost_basis?: Shared.Numeric = "1.0";
  };

  /**
   * Invoice configuration for the credit purchase.
   *
   * Only applicable when `type` is `invoiced`.
   * Controls net terms, memo, auto-collection, and tax code.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  invoice_settings?: CreditInvoiceSettings;

  /**
   * The priority of the credit grant.
   */
  @visibility(Lifecycle.Create, Lifecycle.Read)
  @minValue(1)
  @maxValue(1000)
  priority: int16 = 1;

  /**
   * The effective date of the credit grant.
   */
  @visibility(Lifecycle.Create, Lifecycle.Read)
  effective_at?: Shared.DateTime;

  /**
   * The duration after which the credit grant expires.
   */
  @visibility(Lifecycle.Create, Lifecycle.Read)
  @example("P1Y")
  expires_after?: Shared.ISO8601Duration;

  /**
   * The date the credit grant expires.
   */
  @visibility(Lifecycle.Read)
  expires_at?: Shared.DateTime;

  /**
   * The ID of the invoice generated for an `invoiced` grant.
   */
  @visibility(Lifecycle.Read)
  invoice_id?: string;

  /**
   * When the grant was voided, if applicable.
   */
  @visibility(Lifecycle.Read)
  voided_at?: Shared.DateTime;
}

/**
 * Invoice configuration for `invoiced` credit grants.
 * Controls how the purchase invoice is generated and collected.
 */
@friendlyName("BillingCreditInvoiceSettings")
model CreditInvoiceSettings {
  /**
   * Net terms for the generated invoice, as an ISO 8601 duration.
   * "P0D" means due immediately (due on receipt).
   * "P30D" means net-30.
   *
   * Defaults to "P0D" (due on receipt).
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  @example("P30D")
  net_terms?: Shared.ISO8601Duration = "P0D";

  /**
   * Whether the invoice should be collected automatically
   * via the customer's default payment method.
   *
   * When `false`, the invoice is issued but not auto-charged.
   *
   * Defaults to true.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  auto_collection?: boolean = true;

  /**
   * The tax code to apply to the credit purchase invoice line item.
   *
   * If `null`, the customer's default tax settings apply.
   */
  // @visibility(Lifecycle.Read, Lifecycle.Create)
  // tax_config?: TaxConfig;
}
