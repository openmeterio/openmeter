import "../../shared/index.tsp";
import "../../currencies/index.tsp";

namespace Customers;

/**
 * How the credit grant is funded.
 *
 * - `promotional`: Free credits, no charge or invoice.
 * - `invoice`: Credits purchased via an invoice generated by the system.
 * - `externally_settled`: Credits paid outside the system (e.g. wire, ERP).
 *    The cost basis is recorded for revenue recognition but no invoice is created.
 */
@friendlyName("BillingCreditGrantType")
enum CreditGrantType {
  Promotional: "promotional",
  Invoice: "invoice",
  ExternallySettled: "externally_settled",
}

/**
 * When credits become available for burn-down after a purchase.
 *
 * - `immediate`: Credits are available as soon as the grant is created.
 *    Use for promotional grants or when payment risk is accepted.
 * - `on_payment_authorized`: Credits are available once the payment provider
 *    authorizes the charge (funds are held but not yet captured).
 * - `on_payment_settled`: Credits are available only after the payment is
 *    fully captured/settled. Safest option for prepaid self-serve.
 *
 * Only applicable when `type` is `invoice`. Ignored otherwise.
 */
@friendlyName("BillingCreditAvailabilityPolicy")
enum CreditAvailabilityPolicy {
  Immediate: "immediate",
  OnPaymentAuthorized: "on_payment_authorized",
  OnPaymentSettled: "on_payment_settled",
}

/**
 * The lifecycle status of the credit grant.
 *
 * Grants transition through: `draft → active → consumed | expired | voided` states.
 */
@friendlyName("BillingCreditGrantStatus")
enum CreditGrantStatus {
  /**
   * The credit block has been created but is not yet eligible for consumption:
   *  - `effective_at` is in the future
   *  - `availability_policy` is not `immediate` and waiting for payment to be authorized or settled
   */
  Pending: "pending",

  /**
   * The credit block is currently valid and eligible for consumption.
   * Usage may burn from this block according to configured priority and eligibility rules.
   */
  Active: "active",

  /**
   * All credits in the block have been used.
   */
  Depleted: "depleted",

  /**
   * The credit block has reached its `expires_at` date with remaining balance.
   */
  Expired: "expired",

  /**
   * The credit block was voided by an admin. Remaining balance is forfeited.
   */
  Voided: "voided",
}

/**
 * A credit grant represents an allocation of prepaid credits to a customer.
 *
 * Credits are drawn down against usage-based charges according to the
 * settlement mode configured on the rate card (`invoice` or `credit_only`).
 *
 * ### Charge types
 *
 * | Type                  | Invoice created? | Payment expected? | Use case                          |
 * |-----------------------|------------------|-------------------|-----------------------------------|
 * | `promotional`         | No               | No                | Free trials, promos, SLA credits  |
 * | `invoice`             | Yes              | Yes               | Self-serve prepaid, enterprise    |
 * | `externally_settled`  | No               | Already paid      | Wire transfers, ERP-invoiced      |
 *
 * ### Priority & draw-down
 *
 * When multiple grants are active, credits are consumed in the following
 * order (highest to lowest priority):
 *
 * 1. Scoped match (filters)
 * 2. `priority` field (lower number = higher priority)
 * 3. Earliest expiry (`expires_at`)
 * 4. Lower cost basis (`purchase.per_unit_cost_basis`)
 * 5. Earliest creation (FIFO by `created_at`)
 *
 * When two charges are accounted at the same time the ledger prefers
 * charges with `settlement_mode=invoice` first, then `credit_only`.
 * This minimizes the amount billed on the customer's invoice.
 */
#suppress "@openmeter/api-spec/repeated-prefix-grouping" "invoice_ and expires_ prefixes"
@friendlyName("BillingCreditGrant")
model CreditGrant {
  ...Shared.Resource;

  /**
   * The charge type of this credit grant.
   *
   * Determines whether an invoice is generated, whether payment is expected,
   * and which fields are required/applicable.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  type: CreditGrantType;

  /**
   * The currency of the credit grant.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  currency: Shared.CurrencyCode; // | Currencies.CurrencyCodeCustom;

  /**
   * The amount of the credit grant.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  amount: Shared.Numeric;

  /**
   * The charge that will be used to purchase the credit and to recognize revenue.
   * Omit for promotional credit grants.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  purchase?: {
    /**
     * The currency of the charge.
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    currency: Shared.CurrencyCode;

    /**
     * The amount of the charge.
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    amount: Shared.Numeric;

    /**
     * The cost basis per credit unit.
     *
     * Determines both the charge amount and how revenue is recognized.
     * If `per_unit_cost_basis` is 0.50 and credit amount is $100.00,
     * the total charge is $50.00.
     *
     * Defaults to 1.0 (1:1 ratio between credit and charge currency).
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    per_unit_cost_basis?: Shared.Numeric = "1.0";
  };

  /**
   * Filters for the credit grant.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  filters?: {
    /**
     * Limit the credit grant to specific features.
     * If no features are specified, the credit grant can be used for any feature.
     */
    @example(#["input_tokens", "output_tokens"])
    features?: Shared.ResourceKey[];

    /**
     * Limit the credit grant to specific plans.
     * If no plans are specified, the credit grant can be used for any plan.
     */
    @example(#["free", "pro"])
    plans?: Shared.ResourceKey[];
  };

  /**
   * Invoice configuration for the credit purchase.
   *
   * Only applicable when `type` is `invoice`.
   * Controls net terms, and tax code.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  invoice_settings?: CreditInvoiceSettings;

  /**
   * Controls when credits become available for burn-down.
   *
   * Only applicable when `type` is `invoice`. Defaults to `immediate`.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  availability_policy?: CreditAvailabilityPolicy = CreditAvailabilityPolicy.Immediate;

  /**
   * The priority of the credit grant (lower number = higher priority).
   */
  @visibility(Lifecycle.Create, Lifecycle.Read)
  @minValue(1)
  @maxValue(1000)
  priority: int16 = 10;

  /**
   * The effective date of the credit grant.
   *
   * Defaults to the current date and time.
   */
  @visibility(Lifecycle.Create, Lifecycle.Read)
  effective_at?: Shared.DateTime;

  /**
   * The duration after which the credit grant expires.
   *
   * Defaults to never expiring.
   */
  @visibility(Lifecycle.Create, Lifecycle.Read)
  @example("P1Y")
  expires_after?: Shared.ISO8601Duration;

  /**
   * The date the credit grant expires.
   * Calculated from `effective_at` and `expires_after` if provided.
   */
  @visibility(Lifecycle.Read)
  expires_at?: Shared.DateTime;

  /**
   * The ID of the invoice generated for an `invoice` grant.
   */
  @visibility(Lifecycle.Read)
  invoice_id?: Shared.ULID;

  /**
   * When the grant was voided, if applicable.
   */
  @visibility(Lifecycle.Read)
  voided_at?: Shared.DateTime;

  /**
   * The lifecycle status of the credit grant.
   */
  @visibility(Lifecycle.Read)
  status: CreditGrantStatus;
}

/**
 * Invoice configuration for `invoice` credit grants.
 * Controls how the purchase invoice is generated and collected.
 */
@friendlyName("BillingCreditInvoiceSettings")
model CreditInvoiceSettings {
  /**
   * Net terms for the generated invoice, as an ISO 8601 duration.
   * "P0D" means due immediately (due on receipt).
   * "P30D" means net-30.
   *
   * Defaults to "P0D" (due on receipt).
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  @example("P30D")
  net_terms?: Shared.ISO8601Duration = "P0D";

  /**
   * The tax configuration to apply to the credit purchase invoice line item.
   */
  @visibility(Lifecycle.Read, Lifecycle.Create)
  tax_config?: {
    /**
     * The tax behavior.
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    behavior?: Billing.TaxBehavior;

    /**
     * The tax code.
     */
    @visibility(Lifecycle.Read, Lifecycle.Create)
    tax_code?: Shared.ResourceKey;
  };
}
