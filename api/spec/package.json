{
  "name": "@openmeter/api-spec",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate": "pnpm --filter @openmeter/api-spec-legacy run compile && pnpm --filter @openmeter/api-spec-aip run compile",
    "format": "prettier --list-different --find-config-path --write .",
    "lint": "prettier --check . && pnpm --filter @openmeter/api-spec-legacy run lint && pnpm --filter @openmeter/api-spec-aip run lint",
    "lint:fix": "prettier --write ."
  },
  "devDependencies": {
    "@azure-tools/typespec-client-generator-core": "0.65.4",
    "@redocly/cli": "2.26.0",
    "@types/node": "25.6.0",
    "@typespec/compiler": "1.9.0",
    "@typespec/http": "1.9.1",
    "@typespec/http-client-python": "0.27.2",
    "@typespec/json-schema": "1.9.0",
    "@typespec/openapi": "1.9.0",
    "@typespec/openapi3": "1.9.0",
    "@typespec/prettier-plugin-typespec": "1.9.0",
    "@typespec/rest": "0.79.0",
    "@typespec/versioning": "0.79.0",
    "prettier": "3.8.2",
    "yaml": "2.8.3"
  },
  "exports": {
    "./openapi.yaml": "./packages/legacy/output/openapi.OpenMeterCloud.yaml",
    "./openapi.cloud.yaml": "./packages/legacy/output/openapi.OpenMeterCloud.yaml",
    "./openapi.legacy.yaml": "./packages/legacy/output/openapi.OpenMeter.yaml",
    "./v3/openapi.yaml": "./packages/aip/output/definitions/metering-and-billing/v3/openapi.MeteringAndBilling.yaml"
  },
  "private": true,
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "patchedDependencies": {
      "@typespec/http": "patches/@typespec__http.patch",
      "@typespec/openapi": "patches/@typespec__openapi.patch",
      "@typespec/openapi3": "patches/@typespec__openapi3.patch",
      "@typespec/http-client-python": "patches/@typespec__http-client-python.patch",
      "@typespec/compiler": "patches/@typespec__compiler.patch"
    },
    "onlyBuiltDependencies": [
      "@typespec/http-client-python"
    ],
    "overrides": {
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "protobufjs@<7.5.5": ">=7.5.5"
    }
  }
}
