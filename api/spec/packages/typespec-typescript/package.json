    "@typespec/http": "1.11.0",
    "@typespec/http-client": "0.15.1",
    "@typespec/openapi": "1.11.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@alloy-js/cli": "0.23.0",
    "@types/node": "25.9.2",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "zod": ">=4"
  }
}
