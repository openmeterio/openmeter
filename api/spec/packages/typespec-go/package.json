{
  "name": "@openmeter/typespec-go",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "alloy build",
    "watch": "alloy build --watch",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build && vitest --run",
    "check": "pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@alloy-js/core": "0.23.1",
    "@alloy-js/go": "0.3.0",
    "@openmeter/typespec-sdk": "workspace:*",
    "@typespec/compiler": "1.11.0",
    "@typespec/emitter-framework": "0.17.0",
    "@typespec/http": "1.11.0",
    "@typespec/openapi": "1.11.0"
  },
  "devDependencies": {
    "@alloy-js/cli": "0.23.0",
    "@types/node": "25.9.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
