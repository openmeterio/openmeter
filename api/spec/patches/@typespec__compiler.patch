+                for (const member of desc.members) {
+                    member.enum = en;
+                    en.members.set(member.name, member);
+                }
+            }
+            else {
+                for (const [name, member] of Object.entries(desc.members ?? {})) {
+                    en.members.set(name, this.enumMember.create({ name, value: member, enum: en }));
