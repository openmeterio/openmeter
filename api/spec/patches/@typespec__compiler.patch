+let _realm;
+defineKit({
+    realm: {
+        get() {
+            if (!_realm) {
+                _realm = new Realm(this.program, " typekit realm");
+            }
+            return _realm;
+        },
+        set(realm) {
+            _realm = realm;
+        },
+    },
+});
