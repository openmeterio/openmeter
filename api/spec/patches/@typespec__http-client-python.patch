diff --git a/generator/build/bdist.macosx-10.9-universal2/wheel/pygen/codegen/templates/utils.py.jinja2 b/generator/build/bdist.macosx-10.9-universal2/wheel/pygen/codegen/templates/utils.py.jinja2
