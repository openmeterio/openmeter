+                if (contentType !== "application/json") {
+                    properties.push({
+                        name: "contentType",
+                        decorators: [{ name: "header", args: [] }],
+                        isOptional: false,
+                        schema: { type: "string", enum: [contentType] },
+                    });
+                }
+                models.push({
+                    kind: "model",
+                    scope: scopeAndName.scope,
+                    name: generateResponseModelName(scopeAndName.rawName, statusCode, contentType),
