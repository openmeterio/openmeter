+        schema.minimum = 200;
+        schema.maximum = 299;
+    }
+    else if (statusCode === "3XX") {
+        schema.minimum = 300;
+        schema.maximum = 399;
+    }
+    else if (statusCode === "4XX") {
+        schema.minimum = 400;
+        schema.maximum = 499;
+    }
+    else if (statusCode === "5XX") {
+        schema.minimum = 500;
+        schema.maximum = 599;
+    }
