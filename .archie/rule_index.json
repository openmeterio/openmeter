{
  "by_path_glob": {
    "openmeter/**/*.go": [
      "dep-001",
      "wm-001",
      "lock-002"
    ],
    "app/common/": [
      "dep-002",
      "credits-001",
      "di-001",
      "di-002"
    ],
    "cmd/**/*.go": [
      "dep-004",
      "cfg-001"
    ],
    "openmeter/watermill/**/*.go": [
      "wm-002"
    ],
    "openmeter/billing/worker/**/*.go": [
      "wm-002"
    ],
    "openmeter/notification/**/*.go": [
      "wm-002"
    ],
    "openmeter/**/adapter/**/*.go": [
      "ctx-001",
      "ent-001"
    ],
    "openmeter/billing/charges/**/adapter/**/*.go": [
      "ctx-002"
    ],
    "openmeter/billing/**/*.go": [
      "billing-003",
      "billing-005"
    ],
    "**/*.go": [
      "credits-003"
    ],
    "openmeter/**/httpdriver/**/*.go": [
      "api-001"
    ],
    "api/v3/handlers/**/*.go": [
      "api-001"
    ],
    "api/openapi.yaml": [
      "api-002"
    ],
    "api/openapi.cloud.yaml": [
      "api-002"
    ],
    "api/v3/openapi.yaml": [
      "api-002"
    ],
    "openmeter/ent/db/": [
      "gen-001"
    ],
    "api/spec/": [
      "gen-003",
      "gen-004"
    ],
    "openmeter/ent/schema/": [
      "gen-005",
      "gen-007"
    ],
    "tools/migrate/migrations/": [
      "gen-006",
      "migration-001",
      "migration-002"
    ],
    "openmeter/billing/charges/": [
      "tx-001",
      "test-004"
    ],
    "openmeter/": [
      "tx-002",
      "test-001",
      "test-002",
      "test-003",
      "layer-001",
      "layer-003",
      "kafka-001",
      "http-001",
      "http-002",
      "servicehook-001"
    ],
    "openmeter/ledger/": [
      "credits-002"
    ],
    "./": [
      "build-001",
      "security-001"
    ],
    "cmd/": [
      "layer-002"
    ],
    "openmeter/watermill/": [
      "kafka-002"
    ],
    "openmeter/notification/": [
      "notification-001"
    ],
    "openmeter/billing/": [
      "charges-001",
      "billing-001",
      "billing-002",
      "lock-001"
    ],
    "cmd/server/": [
      "namespace-001"
    ],
    "api/v3/": [
      "api-v3-001"
    ]
  },
  "by_code_shape": [
    {
      "rule_id": "dep-001",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "\"github\\.com/openmeterio/openmeter/app/common\""
        ]
      }
    },
    {
      "rule_id": "dep-004",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "^\\s*go func\\("
        ],
        "must_not_match": [
          "run\\.Add",
          "run\\.Group"
        ]
      }
    },
    {
      "rule_id": "wm-001",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "kafka\\.NewProducer|confluent.*ProduceChannel|sarama.*SendMessage"
        ],
        "must_not_match": [
          "eventbus\\.Publisher",
          "watermill"
        ]
      }
    },
    {
      "rule_id": "wm-002",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "func.*\\*message\\.Message.*error"
        ],
        "must_not_match": [
          "msg\\.Context\\(\\)"
        ]
      }
    },
    {
      "rule_id": "ctx-001",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "\\*entdb\\.Tx"
        ],
        "must_not_match": [
          "entutils\\.TransactingRepo",
          "entutils\\.TransactingRepoWithNoValue"
        ]
      }
    },
    {
      "rule_id": "ctx-002",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "a\\.db\\.\\w+\\."
        ],
        "must_not_match": [
          "entutils\\.TransactingRepo",
          "entutils\\.TransactingRepoWithNoValue"
        ]
      }
    },
    {
      "rule_id": "billing-003",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "charges\\.Charge\\{"
        ]
      }
    },
    {
      "rule_id": "credits-003",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "BillingRegistry\\.Charges\\."
        ],
        "must_not_match": [
          "ChargesServiceOrNil"
        ]
      }
    },
    {
      "rule_id": "lock-002",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "\\.LockForTX\\("
        ],
        "must_not_match": [
          "TransactingRepo",
          "entutils\\.Transacting"
        ]
      }
    },
    {
      "rule_id": "api-001",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "func.*Handler.*ServeHTTP|func.*http\\.ResponseWriter.*\\*http\\.Request"
        ]
      }
    },
    {
      "rule_id": "ent-001",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "\\.ExecContext\\(|\\bdb\\.QueryContext\\("
        ],
        "must_not_match": [
          "// clickhouse",
          "// ClickHouse"
        ]
      }
    },
    {
      "rule_id": "cfg-001",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "viper\\.SetDefault\\("
        ]
      }
    },
    {
      "rule_id": "billing-005",
      "shape": {
        "kind": "regex_in_content",
        "must_match": [
          "billing\\.InvoiceLine\\{"
        ]
      }
    }
  ],
  "for_classifier": [
    "dep-001",
    "dep-002",
    "dep-003",
